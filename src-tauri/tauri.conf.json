{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "QLayer",
  "version": "0.1.0",
  "identifier": "dev.qolayer.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "QLayer",
        "width": 480,
        "height": 464,
        "minWidth": 480,
        "minHeight": 464,
        "maxWidth": 480,
        "maxHeight": 464,
        "center": true,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "category": "DeveloperTool",
    "license": "AGPL-3.0-only",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}

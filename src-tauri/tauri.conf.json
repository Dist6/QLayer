{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "QoLayer",
  "version": "0.1.0",
  "identifier": "dev.qolayer.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "QoLayer",
        "width": 410,
        "height": 370,
        "minWidth": 410,
        "minHeight": 370,
        "maxWidth": 410,
        "maxHeight": 370,
        "center": true,
        "resizable": false,
        "decorations": false,
        "skipTaskbar": true
      },
      {
        "label": "voice-selector",
        "title": "Choose a voice destination",
        "url": "index.html?window=voice-selector",
        "width": 320,
        "height": 280,
        "minWidth": 320,
        "minHeight": 120,
        "maxWidth": 320,
        "maxHeight": 280,
        "visible": false,
        "resizable": false,
        "decorations": false,
        "alwaysOnTop": true,
        "focus": false,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "category": "DeveloperTool",
    "license": "AGPL-3.0-only"
  }
}
